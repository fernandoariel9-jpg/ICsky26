function PanelPersonal({ personal, onLogout }) {
  const [vista, setVista] = useState("tareas");

  return (
    <>
      {vista === "tareas" && (
        <TareasPersonal
          personal={personal}
          onLogout={onLogout}
          setVista={setVista}
        />
      )}

      {vista === "equipos" && (
        <Equipos setVista={setVista} />
      )}
    </>
  );
}
